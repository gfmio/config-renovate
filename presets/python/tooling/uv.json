{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "uv package manager specific configuration",
  "packageRules": [
    {
      "description": "Group uv packages",
      "groupName": "uv",
      "commitMessageTopic": "uv",
      "matchPackageNames": [
        "uv"
      ]
    },
    {
      "description": "Separate major uv updates",
      "matchPackageNames": ["uv"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
