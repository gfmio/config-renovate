{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Sphinx documentation generator package grouping",
  "packageRules": [
    {
      "description": "Group Sphinx and extensions",
      "groupName": "Sphinx",
      "commitMessageTopic": "Sphinx",
      "matchPackageNames": [
        "sphinx",
        "/^sphinx-/",
        "/^sphinxcontrib-/"
      ]
    }
  ]
}
