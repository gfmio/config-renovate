{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Configuration for Python applications, CLIs, and services",
  "extends": [
    ":semanticCommits",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":ignoreUnstable"
  ],
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "packageRules": [
    {
      "description": "Pin all dependencies for applications (reproducibility)",
      "matchDepTypes": ["dependencies"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Update lock files for pinned dependencies",
      "matchDatasources": ["pypi"],
      "lockFileMaintenance": {
        "enabled": true,
        "schedule": ["before 6am on the first day of the month"]
      }
    }
  ]
}
