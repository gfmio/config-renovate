{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "commitMessageAction": "update",
  "commitMessagePrefix": "chore(deps):",
  "commitMessageTopic": "{{depName}}",
  "description": "Configuration for Python applications, CLIs, and services",
  "extends": [
    ":semanticCommits",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":ignoreUnstable"
  ],
  "packageRules": [
    {
      "description": "Pin all dependencies for applications (reproducibility)",
      "matchDepTypes": [
        "dependencies"
      ],
      "rangeStrategy": "pin"
    },
    {
      "description": "Update lock files for pinned dependencies",
      "lockFileMaintenance": {
        "enabled": true,
        "schedule": [
          "before 6am on the first day of the month"
        ]
      },
      "matchDatasources": [
        "pypi"
      ]
    }
  ]
}
