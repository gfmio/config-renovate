{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Kotlin/Java application configuration for standalone apps, CLIs, and backend services",
  "extends": [
    "github>gfmio/config-renovate:presets/kotlin/base"
  ],
  "packageRules": [
    {
      "description": "Pin dependencies for reproducible builds in applications",
      "matchManagers": ["gradle", "maven"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Enable lock file maintenance",
      "matchManagers": ["gradle", "maven"],
      "lockFileMaintenance": {
        "enabled": true
      }
    }
  ]
}
