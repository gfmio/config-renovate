{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Spring Framework and Spring Boot configuration",
  "packageRules": [
    {
      "commitMessageTopic": "Spring Boot",
      "description": "Group Spring Boot dependencies",
      "groupName": "Spring Boot",
      "matchPackagePatterns": [
        "^org\\.springframework\\.boot:",
        "^org\\.springframework\\.boot\\."
      ]
    },
    {
      "commitMessageTopic": "Spring Framework",
      "description": "Group Spring Framework dependencies",
      "excludePackagePatterns": [
        "^org\\.springframework\\.boot:"
      ],
      "groupName": "Spring Framework",
      "matchPackagePatterns": [
        "^org\\.springframework:",
        "^org\\.springframework\\."
      ]
    },
    {
      "commitMessageTopic": "Spring Security",
      "description": "Group Spring Security dependencies",
      "groupName": "Spring Security",
      "matchPackagePatterns": [
        "^org\\.springframework\\.security:"
      ]
    },
    {
      "commitMessageTopic": "Spring Data",
      "description": "Group Spring Data dependencies",
      "groupName": "Spring Data",
      "matchPackagePatterns": [
        "^org\\.springframework\\.data:"
      ]
    }
  ]
}
