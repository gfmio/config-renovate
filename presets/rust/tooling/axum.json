{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Axum web framework package grouping",
  "packageRules": [
    {
      "commitMessageTopic": "Axum",
      "description": "Group Axum packages",
      "groupName": "Axum",
      "matchPackageNames": [
        "axum",
        "axum-extra",
        "axum-core",
        "tower",
        "tower-http"
      ]
    }
  ]
}
