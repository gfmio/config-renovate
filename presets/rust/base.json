{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Base Rust configuration for Cargo projects",
  "extends": [
    "group:recommended",
    "workarounds:all"
  ],
  "packageRules": [
    {
      "description": "Group Rust toolchain updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["rust"],
      "groupName": "Rust toolchain",
      "commitMessageTopic": "Rust toolchain"
    },
    {
      "description": "Separate major Rust version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["rust"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],
  "cargo": {
    "rangeStrategy": "bump"
  }
}
