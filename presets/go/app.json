{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "commitMessageAction": "update",
  "commitMessagePrefix": "chore(deps):",
  "commitMessageTopic": "{{depName}}",
  "description": "Configuration for Go applications, CLIs, and services",
  "extends": [
    ":semanticCommits",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":ignoreUnstable"
  ],
  "packageRules": [
    {
      "description": "Applications can use latest versions",
      "matchManagers": [
        "gomod"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Update go.sum regularly",
      "lockFileMaintenance": {
        "enabled": true,
        "schedule": [
          "before 6am on the first day of the month"
        ]
      },
      "matchManagers": [
        "gomod"
      ]
    }
  ]
}
