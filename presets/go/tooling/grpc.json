{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "gRPC and Protocol Buffers package grouping",
  "packageRules": [
    {
      "description": "Group gRPC and protobuf packages",
      "groupName": "gRPC/Protobuf",
      "commitMessageTopic": "gRPC/Protobuf",
      "matchPackageNames": [
        "google.golang.org/grpc",
        "google.golang.org/protobuf",
        "github.com/grpc/grpc-go"
      ]
    }
  ]
}
