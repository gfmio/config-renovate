{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Cobra CLI framework package grouping",
  "packageRules": [
    {
      "description": "Group Cobra and Viper packages",
      "groupName": "Cobra/Viper",
      "commitMessageTopic": "Cobra/Viper",
      "matchPackageNames": [
        "github.com/spf13/cobra",
        "github.com/spf13/viper",
        "github.com/spf13/pflag"
      ]
    }
  ]
}
