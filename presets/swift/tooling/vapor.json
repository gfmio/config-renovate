{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Vapor web framework package grouping",
  "packageRules": [
    {
      "commitMessageTopic": "Vapor",
      "description": "Group Vapor packages",
      "groupName": "Vapor",
      "matchPackageNames": [
        "https://github.com/vapor/vapor",
        "https://github.com/vapor/fluent",
        "https://github.com/vapor/leaf"
      ]
    }
  ]
}
