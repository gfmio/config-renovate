{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Configuration for Swift applications and command-line tools",
  "extends": [
    ":semanticCommits",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":ignoreUnstable"
  ],
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "packageRules": [
    {
      "description": "Applications can use latest versions",
      "matchManagers": ["swift"],
      "rangeStrategy": "bump"
    }
  ]
}
