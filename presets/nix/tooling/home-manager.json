{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Home Manager configuration",
  "packageRules": [
    {
      "description": "Group Home Manager flake input",
      "matchManagers": ["nix"],
      "matchPackageNames": ["home-manager"],
      "groupName": "Home Manager",
