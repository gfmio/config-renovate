{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "TypeScript package grouping and version management",
  "packageRules": [
    {
      "commitMessageTopic": "TypeScript",
      "description": "Group all TypeScript packages",
      "groupName": "TypeScript",
      "matchPackageNames": [
        "typescript",
        "/^@types\\//"
      ]
    },
    {
      "automerge": false,
      "commitMessageTopic": "TypeScript (major)",
      "description": "Separate major TypeScript updates for breaking changes",
      "groupName": "TypeScript (major)",
      "matchPackageNames": [
        "typescript"
      ],
      "matchUpdateTypes": [
        "major"
      ]
    }
  ]
}
