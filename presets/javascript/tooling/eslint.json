{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "ESLint package grouping",
  "packageRules": [
    {
      "description": "Group all ESLint packages",
      "groupName": "ESLint",
      "commitMessageTopic": "ESLint",
      "matchPackageNames": ["/^eslint/", "/^@eslint\\//"]
    }
  ]
}
