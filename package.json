{
  "name": "@gfmio/config-renovate",
  "version": "0.0.0",
  "description": "Composable Renovate configuration presets for various programming languages and project types",
  "keywords": [
    "renovate",
    "renovate-config",
    "dependency-updates",
    "automation",
    "presets"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gfmio/config-renovate.git"
  },
  "license": "MIT",
  "author": "Frédérique Mittelstaedt <github@gfm.io>",
  "type": "module",
  "files": [
    "default.json",
    "presets/"
  ],
  "scripts": {
    "validate": "bun run validate:json && bun run validate:renovate",
    "validate:json": "node -e \"const fs=require('fs'); process.exit(require('glob').globSync('**/*.json', {ignore: ['node_modules/**', '.git/**']}).map(f => (console.log('✓', f), JSON.parse(fs.readFileSync(f)))).length ? 0 : 1)\"",
    "validate:renovate": "npx --yes renovate-config-validator --strict default.json renovate.json 'presets/**/*.json' 'examples/**/*.json'",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "lint": "biome lint .",
    "check": "biome check --error-on-warnings ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@gfmio/config-biome": "^1.0.2",
    "@gfmio/config-commitlint": "^1.0.1",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "renovate-config": {
    "default": {
      "description": "Default preset - includes base config only",
      "extends": [
        "@gfmio/config-renovate:presets/base"
      ]
    }
  }
}
